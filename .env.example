# Core service configuration
ENV=production
LOG_LEVEL=info
PORT=8080
MIGRATIONS_DIR=/app/migrations

# Discord
DISCORD_TOKEN=__REQUIRED__
DISCORD_PUBLIC_KEY=__REQUIRED__
DISCORD_APPLICATION_ID=
GUILD_ID=__REQUIRED__
GIVEAWAY_ROLE_ID=__REQUIRED__

# GitHub OAuth + repo checks
GITHUB_CLIENT_ID=__REQUIRED__
GITHUB_CLIENT_SECRET=__REQUIRED__
GITHUB_REPO=Producdevity/EmuReady
GITHUB_OAUTH_SCOPE=
BASE_URL=https://giveaway.emuready.com
SIGNING_SECRET=__REQUIRED__

# Database
DATABASE_URL=postgres://user:pass@localhost:5432/giveaway?sslmode=disable
POSTGRES_PASSWORD=__REQUIRED_FOR_COMPOSE_PROD__
IMAGE=ghcr.io/producdevity/emuready-discord-giveaway:latest

# Timings/limits
STATE_TTL_SECONDS=600
WINNER_DEFAULT_COUNT=1
WINNER_MAX=50
WINNER_CONCURRENCY=10
WINNER_WORKER_COUNT=2
HTTP_MAX_RETRIES=3
HTTP_TIMEOUT_SECONDS=10
DB_CONNECT_TIMEOUT_SECONDS=30
MAX_INTERACTION_BODY_BYTES=65536

# Optional GitHub API token (increases rate limits)
GITHUB_API_TOKEN=
